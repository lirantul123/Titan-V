# Optional: override default http://localhost:3000
# VITE_API_BASE=http://127.0.0.1:3000

# Required for signed-in "Coordinate registry" when the API uses Supabase (same project URL + public key from dashboard)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_...   (new publishable key) OR legacy anon JWT eyJ...
# Do NOT put the secret / service_role key here — that belongs only in api/.env as SUPABASE_SERVICE_ROLE_KEY.
