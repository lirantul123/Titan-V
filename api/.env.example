# API — copy to `.env` (never commit real secrets)
# `npm run dev` / `npm start` load this file automatically via dotenv (see src/index.ts).

PORT=3000

# Required for per-user areas: when unset, the API uses ONE in-memory registry for everyone
# (signed-in browsers would still see each other's rows). Set both to the same Supabase project as the app.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
